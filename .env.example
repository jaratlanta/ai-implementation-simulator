# Anthropic API Key (primary LLM for text generation)
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here
VITE_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Gemini API Key (primary for image generation, fallback for text)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-2.0-flash

# Grok API Key (fallback for image generation)
VITE_GROK_API_KEY=your_grok_api_key_here

# Server
VITE_API_URL=http://localhost:7811
